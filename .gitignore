# Build outputs
build/
.gradle/
out/

# VitePress build outputs and dev caches
docs/.vitepress/dist/
docs/.vitepress/cache/

# Generated Javadoc staged for VitePress public assets (built fresh on every
# docs-deploy CI run from `./gradlew javadoc`; `npm run docs:javadoc` does
# the same for local previews). The committed source of truth is the Java
# code; the HTML tree is reproducible from it.
docs/public/api/javadoc/

# Node.js dependencies (committed lockfile, not the resolved tree)
node_modules/

# IDE files
.idea/
*.iml
.vscode/
.project
.classpath
.settings/
*.swp
*~

# OS files
.DS_Store
Thumbs.db

# p4c intermediate compilation artefacts (not source, not deliverable)
*.p4i

# Publishing secrets — these never belong in the repo. Local development and
# release operations should put credentials in ~/.gradle/gradle.properties
# (user home) or in environment variables instead. See RELEASING.md.
/gradle.properties
**/secring.*
*.gpg
*.kbx
